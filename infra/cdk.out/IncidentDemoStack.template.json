  "NotifyFn73D5825E": {
   "Type": "AWS::Lambda::Function",
   "Properties": {
    "Code": {
     "ZipFile": "\nimport base64\nimport gzip\nimport json\nimport os\n\nimport boto3\n\nsns = boto3.client(\"sns\")\n\n\ndef handler(event, _ctx):\n    data = json.loads(gzip.decompress(base64.b64decode(event[\"awslogs\"][\"data\"])))\n    log_group = data[\"logGroup\"]\n    log_stream = data[\"logStream\"]\n    task_id = log_stream.split(\"/\")[-1]   # awslogs: \"batch/batch/<taskId>\"\n    region = os.environ[\"REGION\"]\n    cluster = os.environ[\"CLUSTER_NAME\"]\n    repo = os.environ[\"GITHUB_REPO\"]\n    account = os.environ[\"ACCOUNT_ID\"]\n    task_arn = f\"arn:aws:ecs:{region}:{account}:task/{cluster}/{task_id}\"\n    run_url = \"https://github.com/\" + repo + \"/actions/workflows/triage.yml\"  # 旧表記(波括弧表示の都合で壊れていたため連結に修正): \"https://github.com/{repo}/actions/workflows/triage.yml\"\n    msgs = \"\\\\n\".join(e[\"message\"] for e in data[\"logEvents\"])\n    body = (\n        \"バッチでエラーを検知しました。起票すると判断したら以下を実行してください。\\\\n\\\\n\"\n        f\"[1] GitHub Actions を開く: {run_url}\\\\n\"\n        \"[2] 「Run workflow」を押し、次の2つを入力して実行:\\\\n\"\n        f\"    task_arn   = {task_arn}\\\\n\"\n        f\"    log_stream = {log_stream}\\\\n\\\\n\"\n        f\"cluster   = {cluster}\\\\n\"\n        f\"log_group = {log_group}\\\\n\\\\n\"\n        \"----- 検知ログ -----\\\\n\" + msgs\n    )\n    sns.publish(TopicArn=os.environ[\"TOPIC_ARN\"],\n                Subject=\"[障害][nightly-etl] エラー検知 - 起票評価をお願いします\",\n                Message=body)\n"
    },
    "Environment": {
     "Variables": {
      "TOPIC_ARN": {
       "Ref": "IncidentTopicC2D68739"
      },
      "CLUSTER_NAME": {
       "Ref": "ClusterEB0386A7"
      },
      "LOG_GROUP": {
       "Ref": "BatchLogsA0B94732"
      },
      "GITHUB_REPO": "kitsukawa-s/ai-driven-dev-starter-kit",
      "REGION": "ap-northeast-1",
      "ACCOUNT_ID": "395947696061"
     }
    },
    "Handler": "index.handler",
    "Role": {
     "Fn::GetAtt": [
      "NotifyFnServiceRoleAEF697F4",
      "Arn"
     ]
    },
    "Runtime": "python3.12",
    "Timeout": 30
   },
   "DependsOn": [
    "NotifyFnServiceRoleDefaultPolicy1CDEFE4C",
    "NotifyFnServiceRoleAEF697F4"
   ],
   "Metadata": {
    "aws:cdk:path": "IncidentDemoStack/NotifyFn/Resource"
   }
  },
