DefaultPolicy/Resource","constructInfo":{"fqn":"aws-cdk-lib.aws_iam.CfnPolicy","version":"2.260.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::IAM::Policy","aws:cdk:cloudformation:logicalId":"NotifyFnServiceRoleDefaultPolicy1CDEFE4C","aws:cdk:cloudformation:props":{"policyDocument":{"Statement":[{"Action":"sns:Publish","Effect":"Allow","Resource":{"Ref":"IncidentTopicC2D68739"}}],"Version":"2012-10-17"},"policyName":"NotifyFnServiceRoleDefaultPolicy1CDEFE4C","roles":[{"Ref":"NotifyFnServiceRoleAEF697F4"}]}}}}}}},"Resource":{"id":"Resource","path":"IncidentDemoStack/NotifyFn/Resource","constructInfo":{"fqn":"aws-cdk-lib.aws_lambda.CfnFunction","version":"2.260.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Lambda::Function","aws:cdk:cloudformation:logicalId":"NotifyFn73D5825E","aws:cdk:cloudformation:props":{"code":{"zipFile":"\nimport base64\nimport gzip\nimport json\nimport os\n\nimport boto3\n\nsns = boto3.client(\"sns\")\n\n\ndef handler(event, _ctx):\n    data = json.loads(gzip.decompress(base64.b64decode(event[\"awslogs\"][\"data\"])))\n    log_group = data[\"logGroup\"]\n    log_stream = data[\"logStream\"]\n    task_id = log_stream.split(\"/\")[-1]   # awslogs: \"batch/batch/<taskId>\"\n    region = os.environ[\"REGION\"]\n    cluster = os.environ[\"CLUSTER_NAME\"]\n    repo = os.environ[\"GITHUB_REPO\"]\n    account = os.environ[\"ACCOUNT_ID\"]\n    task_arn = f\"arn:aws:ecs:{region}:{account}:task/{cluster}/{task_id}\"\n    run_url = \"https://github.com/\" + repo + \"/actions/workflows/triage.yml\"  # 旧表記(波括弧表示の都合で壊れていたため連結に修正): \"https://github.com/{repo}/actions/workflows/triage.yml\"\n    msgs = \"\\n\".join(e[\"message\"] for e in data[\"logEvents\"])\n    cmd = (f\"gh workflow run triage.yml -R {repo} \"\n           f\"-f task_arn='{task_arn}' -f log_stream='{log_stream}'\")\n    body = (\n        \"■ バッチ nightly-etl でエラーを検知しました。\\n\"\n        \"起票すると判断したら、次の A か B のどちらかで triage を実行してください。\\n\\n\"\n        \"=== 方法A: GitHub CLI（この1行をそのままコピペ実行）===\\n\"\n        f\"{cmd}\\n\\n\"\n        \"=== 方法B: ブラウザ ===\\n\"\n        f\"1) 次のURLを開く: {run_url}\\n\"\n        \"2) 右上の「Run workflow」を押す\\n\"\n        \"3) 表示される2つの入力欄に、以下をそのまま貼り付けて Run:\\n\"\n        f\"   - task_arn   = {task_arn}\\n\"\n        f\"   - log_stream = {log_stream}\\n\\n\"\n        \"※ 必須は log_stream（ログから原因箇所とコミットSHAを特定します）。task_arn は予備（フォールバック用）です。\\n\\n\"\n        f\"[参考] cluster   = {cluster}\\n\"\n        f\"[参考] log_group = {log_group}\\n\\n\"\n        \"----- 検知ログ -----\\n\" + msgs\n    )\n    sns.publish(TopicArn=os.environ[\"TOPIC_ARN\"],\n                Subject=\"[障害][nightly-etl] エラー検知 - 起票評価をお願いします\",\n                Message=body)\n"},"environment":{"variables":{"TOPIC_ARN":{"Ref":"IncidentTopicC2D68739"},"CLUSTER_NAME":{"Ref":"ClusterEB0386A7"},"LOG_GROUP":{"Ref":"BatchLogsA0B94732"},"GITHUB_REPO":"kitsukawa-s/ai-driven-dev-starter-kit","REGION":"ap-northeast-1","ACCOUNT_ID":"395947696061"}},"handler":"index.handler","role":{"Fn::GetAtt":["NotifyFnServiceRoleAEF697F4","Arn"]},"runtime":"python3.12","timeout":30}}}}},"ErrorSub":{"id":"ErrorSub","path":"IncidentDemoStack/ErrorSub","constructInfo":{"fqn":"aws-cdk-lib.aws_logs.SubscriptionFilter","version":"2.260.0"},"children":{"CanInvokeLambda":{"id":"CanInvokeLambda","path":"IncidentDemoStack/ErrorSub/CanInvokeLambda","constructInfo":{"fqn":"aws-cdk-lib.aws_lambda.CfnPermission","version":"2.260.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Lambda::Permission","aws:cdk:cloudformation:logicalId":"ErrorSubCanInvokeLambda2DDDEBBD","aws:cdk:cloudformation:props":{"action":"lambda:InvokeFunction","functionName":{"Fn::GetAtt":["NotifyFn73D5825E","Arn"]},"principal":"logs.amazonaws.com","sourceArn":{"Fn::GetAtt":["BatchLogsA0B94732","Arn"]}}}},"Resource":{"id":"Resource","path":"IncidentDemoStack/ErrorSub/Resource","constructInfo":{"fqn":"aws-cdk-lib.aws_logs.CfnSubscriptionFilter","version":"2.260.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Logs::SubscriptionFilte